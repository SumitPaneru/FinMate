{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about the application user",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique identification from Firebase Auth" },
        "email": { "type": "string", "format": "email", "description": "The user's email address" },
        "displayName": { "type": "string", "description": "The user's display name" },
        "photoURL": { "type": "string", "format": "uri", "description": "URL to the user's profile picture" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User's role in the system" },
        "currency": { "type": "string", "description": "Preferred currency code" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created" }
      },
      "required": ["uid", "email"]
    },
    "Transaction": {
      "title": "Finance Transaction",
      "description": "A single transaction entry (income or expense)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number", "minimum": 0 },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "currency": { "type": "string", "enum": ["USD", "NPR"] },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "description", "type", "category", "date", "userId"]
    },
    "Invoice": {
      "title": "Financial Invoice",
      "description": "An invoice document sent to a client",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "clientName": { "type": "string" },
        "clientEmail": { "type": "string", "format": "email" },
        "clientCompany": { "type": "string" },
        "clientAddress": { "type": "string" },
        "fromName": { "type": "string" },
        "fromDetails": { "type": "string" },
        "toDetails": { "type": "string" },
        "issuedDate": { "type": "string", "format": "date" },
        "dueDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["draft", "sent", "paid", "overdue"] },
        "subtotal": { "type": "number" },
        "taxTotal": { "type": "number" },
        "discount": { "type": "number" },
        "total": { "type": "number" },
        "notes": { "type": "string" },
        "terms": { "type": "string" },
        "currency": { "type": "string", "enum": ["USD", "NPR"] },
        "items": { "type": "array" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["invoiceNumber", "clientName", "issuedDate", "dueDate", "status", "total", "userId"]
    },
    "Debt": {
      "title": "Liability/Debt",
      "description": "A debt or loan being tracked",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "totalAmount": { "type": "number" },
        "remainingAmount": { "type": "number" },
        "interestRate": { "type": "number" },
        "dueDate": { "type": "string", "format": "date" },
        "type": { "type": "string", "enum": ["loan", "credit_card", "mortgage", "other"] },
        "currency": { "type": "string", "enum": ["USD", "NPR"] },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "totalAmount", "remainingAmount", "interestRate", "dueDate", "type", "userId"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Storage for user profile information"
    },
    "users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "User's financial transactions"
    },
    "users/{userId}/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Invoices generated by the user"
    },
    "users/{userId}/debts/{debtId}": {
      "schema": "Debt",
      "description": "Debts tracked by the user"
    }
  }
}
